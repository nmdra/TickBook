# ──── Event Service Configuration ────

# Server
PORT=3001

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eventdb

# Redis (used for caching)
REDIS_HOST=localhost
REDIS_PORT=6379

# Apache Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_RECONNECT_INTERVAL_MS=15000
