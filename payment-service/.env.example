# Copy this file to .env and replace placeholder values before running locally.
# ──── Payment Service Configuration ────

# Server
PORT=3004

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=paymentdb

# Apache Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_RECONNECT_INTERVAL_MS=15000

# Inter-service communication (REST)
BOOKING_SERVICE_URL=http://localhost:3003

# Stripe
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=http://localhost:3004/api/payments/stripe/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3004/api/payments/stripe/cancel?session_id={CHECKOUT_SESSION_ID}
