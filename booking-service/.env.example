# ──── Booking Service Configuration ────

# Server
PORT=3003

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bookingdb

# Apache Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_BOOKINGS_TOPIC=bookings
KAFKA_PAYMENTS_TOPIC=payments
KAFKA_PAYMENTS_GROUP=booking-service
KAFKA_SEAT_LOCK_GROUP=booking-seat-lock-processor

# Redis (seat lock store)
REDIS_ADDR=localhost:6379

# Inter-service communication (REST)
EVENT_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
